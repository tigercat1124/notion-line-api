{
  "name": "Python Zero-Config Development",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "latest",
      "installTools": true,
      "installJupyterlab": true
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "ms-python.isort",
        "ms-python.flake8",
        "ms-python.mypy-type-checker",
        "njpwerner.autodocstring",
        "kevinrose.vsc-python-indent",
        "magicstack.magicpython",
        "wayou.vscode-todo-highlight",
        "github.vscode-github-actions",
        "ms-azuretools.vscode-docker",
        "ms-toolsai.jupyter",
        "saoudrizwan.claude-dev",
        "eamodio.gitlens",
        "mhutchie.git-graph",
        "streetsidesoftware.code-spell-checker"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.languageServer": "Pylance",
        
        // フォーマッター設定
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports": "explicit"
        },
        "python.formatting.provider": "none",
        "python.formatting.blackArgs": ["--line-length", "88"],
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter",
          "editor.formatOnSave": true
        },
        
        // リンター設定
        "python.linting.enabled": true,
        "python.linting.lintOnSave": true,
        "python.linting.flake8Enabled": true,
        "python.linting.flake8Args": ["--max-line-length=88", "--ignore=E203,W503"],
        "python.linting.mypyEnabled": true,
        
        // テスト設定
        "python.testing.pytestEnabled": true,
        "python.testing.unittestEnabled": false,
        "python.testing.nosetestsEnabled": false,
        "python.testing.pytestArgs": [
          "tests"
        ]
      }
    }
  },
  "containerEnv": {
    "PYTHONPATH": "${containerWorkspaceFolder}"
  },
  "postCreateCommand": "pip install --upgrade pip && pip install poetry && poetry config virtualenvs.in-project true && poetry install --no-interaction || (pip install pytest pytest-asyncio pytest-cov black flake8 mypy isort python-dotenv notion-client && pip install -r requirements.txt 2>/dev/null || echo 'No requirements.txt found, using Poetry or installing common dependencies')"
}